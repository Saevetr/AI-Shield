{
  "expo": {
    "name": "my-ui-app",
    "slug": "my-ui-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myuiapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "允許 AI Shield 使用語音辨識功能。",
        "NSMicrophoneUsageDescription": "允許 AI Shield 使用麥克風進行語音輸入。",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.fishball0.x0.myuiapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.fishball0.x0.myuiapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "允許 AI Shield 存取相簿，用來選擇個人頭像。"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "允許 AI Shield 使用麥克風進行語音輸入。",
          "speechRecognitionPermission": "允許 AI Shield 使用語音辨識功能。",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6779d2a2-02c0-4231-b74f-a4d5340f6fa1"
      }
    }
  }
}
